<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_gray">

    <TextView
        android:id="@+id/text_tittle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/e_ukraine_bold"
        android:gravity="start"
        android:text="@string/soldier_add_tittle"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintTop_toTopOf="@+id/gl_hor_top" />

    <ImageView
        android:id="@+id/close"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="5dp"
        android:background="@drawable/frame_blue"
        android:src="@drawable/img_cross"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end"
        app:layout_constraintTop_toTopOf="@+id/text_tittle"
        app:layout_constraintBottom_toBottomOf="@+id/text_tittle"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/add"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:background="@drawable/frame_blue"
        android:fontFamily="@font/e_ukraine_regular"
        android:gravity="center"
        android:stateListAnimator="@null"
        android:text="@string/soldier_add_button"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/gl_hor_button"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/add"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintTop_toBottomOf="@+id/text_tittle">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/last_name_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_last_name"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/last_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/e_ukraine_regular"
                android:gravity="center_vertical"
                android:hint="@string/soldier_add_last_name"
                android:inputType="textPersonName"
                android:minHeight="40dp"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="@color/light_gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@+id/last_name_label" />

            <TextView
                android:id="@+id/first_name_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_first_name"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/last_name" />

            <EditText
                android:id="@+id/first_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/e_ukraine_regular"
                android:gravity="center_vertical"
                android:hint="@string/soldier_add_first_name"
                android:inputType="textPersonName"
                android:minHeight="40dp"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="#80FFFFFF"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@+id/first_name_label" />

            <TextView
                android:id="@+id/middle_name_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_middle_name"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/first_name" />

            <EditText
                android:id="@+id/middle_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/e_ukraine_regular"
                android:gravity="center_vertical"
                android:hint="@string/soldier_add_middle_name"
                android:inputType="textPersonName"
                android:minHeight="40dp"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="#80FFFFFF"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@+id/middle_name_label" />

            <TextView
                android:id="@+id/rank_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_rank"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/middle_name" />

            <EditText
                android:id="@+id/rank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/e_ukraine_regular"
                android:gravity="center_vertical"
                android:hint="@string/soldier_add_rank"
                android:inputType="text"
                android:minHeight="40dp"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="#80FFFFFF"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@+id/rank_label" />

            <TextView
                android:id="@+id/birth_date_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_birth_day"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/rank" />

            <LinearLayout
                android:id="@+id/birth_date_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/birth_date_label">

                <EditText
                    android:id="@+id/birth_day"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/e_ukraine_regular"
                    android:gravity="center"
                    android:hint="@string/soldier_add_birth_day_hint"
                    android:inputType="number"
                    android:maxLength="2"
                    android:minHeight="40dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp" />

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <EditText
                    android:id="@+id/birth_month"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/e_ukraine_regular"
                    android:gravity="center"
                    android:hint="@string/soldier_add_birth_month_hint"
                    android:inputType="number"
                    android:maxLength="2"
                    android:minHeight="40dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp" />

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <EditText
                    android:id="@+id/birth_year"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:background="@drawable/bg_edit_text"
                    android:fontFamily="@font/e_ukraine_regular"
                    android:gravity="center"
                    android:hint="@string/soldier_add_birth_year_hint"
                    android:inputType="number"
                    android:maxLength="4"
                    android:minHeight="40dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/iot_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="@string/soldier_add_iot_serial"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@+id/birth_date_container" />

            <EditText
                android:id="@+id/iot_serial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:fontFamily="@font/e_ukraine_regular"
                android:gravity="center_vertical"
                android:hint="@string/soldier_add_iot_serial"
                android:inputType="text"
                android:minHeight="40dp"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="#80FFFFFF"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@+id/iot_label" />

            <TextView
                android:id="@+id/error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="null"
                android:textSize="10sp"
                android:textColor="@color/light_red"
                android:fontFamily="@font/e_ukraine_thin"
                android:gravity="center"
                android:visibility="invisible"
                app:layout_constraintTop_toBottomOf="@+id/iot_serial"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_hor_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_ver_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_ver_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_hor_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.9" />
</androidx.constraintlayout.widget.ConstraintLayout>