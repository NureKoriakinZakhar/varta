<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_gray">

    <ImageView
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginBottom="40dp"
        android:scaleType="centerInside"
        android:background="@null"
        android:src="@drawable/img_logo"
        app:layout_constraintHeight_percent="0.13"
        app:layout_constraintBottom_toTopOf="@id/gl_hor_main"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end" />

    <EditText
        android:id="@+id/username"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:paddingHorizontal="15dp"
        android:inputType="textEmailAddress"
        android:hint="@string/login_email"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:textColorHint="@color/light_gray"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/e_ukraine_regular"
        android:textCursorDrawable="@drawable/bg_cursor"
        app:layout_constraintTop_toBottomOf="@id/gl_hor_main"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end" />

    <EditText
        android:id="@+id/password"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginTop="15dp"
        android:paddingHorizontal="15dp"
        android:inputType="textPassword"
        android:hint="@string/login_password"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:textColorHint="@color/light_gray"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="@font/e_ukraine_regular"
        android:textCursorDrawable="@drawable/bg_cursor"
        app:layout_constraintTop_toBottomOf="@id/username"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end" />

    <ImageView
        android:id="@+id/password_toggle"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="6dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/img_unvisible_password"
        android:padding="5dp"
        app:layout_constraintTop_toTopOf="@id/password"
        app:layout_constraintBottom_toBottomOf="@id/password"
        app:layout_constraintEnd_toEndOf="@id/password" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/login"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/frame_blue"
        android:text="@string/login_button"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="@font/e_ukraine_regular"
        android:gravity="center"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/password"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end" />

    <TextView
        android:id="@+id/error"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="null"
        android:textSize="10sp"
        android:textColor="@color/light_red"
        android:fontFamily="@font/e_ukraine_thin"
        android:gravity="center"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/login"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end" />

    <LinearLayout
        android:id="@+id/llSupport"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="@id/gl_ver_end"
        app:layout_constraintStart_toStartOf="@id/gl_ver_start"
        app:layout_constraintTop_toTopOf="@+id/gl_hor_support">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/e_ukraine_regular"
            android:gravity="start"
            android:text="@string/login_support"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="E-mail:"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="support@mil.gov.ua"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="Telegram:"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:fontFamily="@font/e_ukraine_regular"
                android:text="+380 66 123 45 67"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_hor_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.35" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_hor_support"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.8" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_ver_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_ver_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />
</androidx.constraintlayout.widget.ConstraintLayout>